# -----------------------------------------------------------------------------
# Database connection strategy (set once, tune numbers as you scale)
#
# Pipeline at scale:  app pool → ProxySQL → Cloud SQL
# Pipeline in dev:     app pool → Cloud SQL Connector → Cloud SQL
#                      (or app pool → ProxySQL → MySQL, same TCP path as prod)
#
# Layer 1 — fixed pool per container (never grows with traffic)
DB_POOL_SIZE=5
#
# Layer 2 — Cloud SQL Connector (encrypted, IAM-capable; no raw host/port to Cloud SQL)
# Use in dev and for direct Cloud SQL access. Requires Application Default Credentials
# (gcloud auth application-default login) or a service account in Cloud Run.
# DB_CONNECT_MODE=cloud-sql
# CLOUD_SQL_CONNECTION_NAME=your-gcp-project:region:instance-name
# CLOUD_SQL_IP_TYPE=PUBLIC
#
# Layer 3 — ProxySQL multiplexer (prod scale path; same TCP interface as local MySQL)
# Point DB_HOST at ProxySQL, never at Cloud SQL directly from Cloud Run.
DB_CONNECT_MODE=tcp
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=webhouse_project_x

# Auth (required) — stateless JWT; no admin session table in DB
JWT_SECRET=your_long_random_secret_min_32_chars

# Auth (optional)
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── Shopify Public App ──
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,read_all_orders,read_products,read_customers,read_inventory,read_locations
# Public HTTPS base for OAuth + webhooks (e.g. ngrok in dev)
SHOPIFY_WEBHOOK_BASE_URL=
SHOPIFY_REDIRECT_URI=

# ── Daraz Open Platform ──
DARAZ_APP_KEY=
DARAZ_APP_SECRET=
DARAZ_API_BASE=api.daraz.pk
DARAZ_OAUTH_REDIRECT_URI=
